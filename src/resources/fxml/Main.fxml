<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="480.0" prefWidth="640.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.MainController">
  <columnConstraints>
    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
  </columnConstraints>
  <rowConstraints>
    <RowConstraints maxHeight="-Infinity" minHeight="10.0" prefHeight="36.0" vgrow="SOMETIMES" />
    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
    <RowConstraints maxHeight="-Infinity" minHeight="10.0" prefHeight="25.0" vgrow="SOMETIMES" />
  </rowConstraints>
   <children>
      <MenuBar minHeight="-Infinity" prefWidth="320.0" GridPane.columnSpan="2">
        <menus>
          <Menu mnemonicParsing="false" text="Файл">
            <items>
              <MenuItem fx:id="saveText" mnemonicParsing="false" onAction="#saveText" text="Сохранить" />
                  <MenuItem mnemonicParsing="false" onAction="#saveTextAs" text="Сохранить как..." />
                  <MenuItem mnemonicParsing="false" onAction="#openTextFile" text="Загрузить" />
            </items>
          </Menu>
            <Menu mnemonicParsing="false" text="Правка">
               <items>
                  <MenuItem fx:id="undo" mnemonicParsing="false" text="Отменить" />
                  <MenuItem fx:id="redo" mnemonicParsing="false" text="Повторить" />
               </items>
            </Menu>
          <Menu mnemonicParsing="false" text="Опции">
            <items>
              <MenuItem disable="true" mnemonicParsing="false" text="Настройки" />
                  <SeparatorMenuItem mnemonicParsing="false" />
                  <MenuItem mnemonicParsing="false" onAction="#openInfoWindow" text="О программе" />
            </items>
          </Menu>
          <Menu fx:id="exit" mnemonicParsing="false" onMenuValidation="#exitNotepad1" onShown="#hideExit" text="Выход">
               <items>
                  <MenuItem mnemonicParsing="false" text="Hello, World!" />
               </items></Menu>
        </menus>
      </MenuBar>
      <TextArea fx:id="textArea" prefHeight="200.0" prefWidth="200.0" promptText="Введите текст..." GridPane.columnSpan="2" GridPane.rowIndex="1" />
      <Label fx:id="positionLabel" maxWidth="-Infinity" scaleX="0.9" scaleY="0.9" text="Строка 1, столбец 1" GridPane.halignment="LEFT" GridPane.rowIndex="2">
         <GridPane.margin>
            <Insets />
         </GridPane.margin>
         <padding>
            <Insets left="5.0" />
         </padding>
      </Label>
      <Label fx:id="charsetLabel" alignment="CENTER_RIGHT" maxWidth="-Infinity" scaleX="0.9" scaleY="0.9" text="UTF-8" GridPane.columnIndex="1" GridPane.halignment="RIGHT" GridPane.rowIndex="2">
         <GridPane.margin>
            <Insets />
         </GridPane.margin>
         <padding>
            <Insets right="10.0" />
         </padding>
      </Label>
   </children>
</GridPane>
